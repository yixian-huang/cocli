{
  "version": "2026-06-03",
  "commands": [
    {
      "action": "message.digest",
      "tool": "message_digest",
      "cli": [
        "message",
        "digest"
      ],
      "tier": "core",
      "section": "Messaging",
      "summary": "non-consuming server-authoritative digest (relevance previews + signal counts; does not advance read cursor)",
      "example": "cocli message digest [--since last]",
      "flags": [
        "--since"
      ]
    },
    {
      "action": "message.check",
      "tool": "check_messages",
      "cli": [
        "message",
        "check"
      ],
      "tier": "core",
      "section": "Messaging",
      "summary": "fetch unread inbox with triaged digest + DIRECT/HIGH full bodies",
      "example": "cocli message check"
    },
    {
      "action": "message.drill",
      "tool": "drill_inbox",
      "cli": [
        "message",
        "drill"
      ],
      "tier": "extended",
      "section": "Messaging",
      "summary": "full bodies for a category previewed in the last check (run check first)",
      "example": "cocli message drill --category peer_update",
      "flags": [
        "--category"
      ]
    },
